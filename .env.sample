# ─── Account ───
X_USERNAME=your_username
X_PROFILE_URL=https://x.com/your_username

# ─── Community ───
# Leave blank to skip community posting
COMMUNITY_URL=
# Additional community URLs can be managed via CLI: community add <url>

# ─── Posting Schedule (minutes) ───
# One post per cycle. ~1 post/hour with defaults.
POST_INTERVAL_MIN=55
POST_INTERVAL_MAX=65

# ─── Reply Schedule (minutes) ───
# One reply per cycle. Randomly spaced.
REPLY_INTERVAL_MIN=5
REPLY_INTERVAL_MAX=25

# ─── Reply Toggle ───
# Set to false to disable reply engagement entirely
REPLIES_ENABLED=true

# ─── Browser ───
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36
# Set to true if Puppeteer should run with a visible browser (debugging)
HEADLESS=true
